# Anvil environment variables
# Copy to .env and fill in values. These override anvil.toml for secrets.
# The .env file should NEVER be committed to git.

# ── Identity (required for mesh peering + wallet) ──
# BRC-42 identity root key. Generate with: go-sdk keygen or any BSV wallet.
ANVIL_IDENTITY_WIF=

# ── API auth ──
# Bearer token for write endpoints (POST /broadcast, POST /data, wallet, overlay).
# Generate a random string: openssl rand -hex 32
ANVIL_API_AUTH_TOKEN=

# ── ARC (optional — for miner submission + tx status) ──
# GorillaPool ARC (free, no API key required for basic use):
#   ANVIL_ARC_URL=https://arc.gorillapool.io
# TAAL ARC (requires API key from taal.com):
#   ANVIL_ARC_URL=https://arc.taal.com
#   ANVIL_ARC_API_KEY=your-taal-api-key
ANVIL_ARC_URL=
ANVIL_ARC_API_KEY=

# ── JungleBus (optional — for live SHIP/SLAP overlay discovery) ──
# GorillaPool JungleBus (free):
#   ANVIL_JUNGLEBUS_URL=junglebus.gorillapool.io
ANVIL_JUNGLEBUS_URL=

# ── TLS (optional — for production HTTPS + wss://) ──
# Paths to TLS certificate and key. If both set, API serves HTTPS
# and mesh listener uses wss://.
ANVIL_TLS_CERT=
ANVIL_TLS_KEY=
